# Pure Local Sermon Pipeline Configuration
# Copy to sermon_local.env and fill in values.
# This file should NEVER be committed.

# --- Claude (Anthropic API) ---
ANTHROPIC_API_KEY=<your-anthropic-api-key>
LLM_MODEL=claude-sonnet-4-20250514
LLM_PROVIDER=anthropic

# --- GitHub ---
GITHUB_TOKEN=<fine-grained-pat-with-contents-write>
GITHUB_REPO=ebdtcode/TrustingJesus
GITHUB_BRANCH=main

# --- Local Whisper ---
# Models: tiny, base, small, medium, large-v2, large-v3
# large-v3 is most accurate, base/small are faster
WHISPER_MODEL=large-v3
# auto detects CUDA/CPU. Force with: cuda, cpu
WHISPER_DEVICE=auto
# auto picks optimal. Options: int8 (fast CPU), float16 (GPU), float32
WHISPER_COMPUTE=auto

# --- yt-dlp Cookie Auth (choose ONE) ---
# Option 1: Netscape cookies file (exported from browser)
YTDLP_COOKIES_FILE=/home/devos/prayer_trusting_Jesus/tools/cookies.txt
# Option 2: Read directly from browser (needs browser on VM)
#YTDLP_COOKIES_BROWSER=chrome

# --- Processing ---
MAX_VIDEOS_PER_RUN=3
AUDIO_QUALITY=32K
CHURCH_NAME=

# --- Logging ---
SERMON_MONITOR_LOG=/var/log/sermon-monitor/local.log
